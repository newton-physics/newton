                (2.39999986, -0.0699999928, 1.29999995), (2.39999986, -0.0699999928, 1.29999995), (2.39999986, -0.0699999928, 1.29999995),
                (2.39999986, -0.0699999928, 1.29999995), (2.39999986, -0.0699999928, 1.29999995), (2.39999986, -0.0699999928, 1.29999995),
                (2.39999986, -0.0699999928, 1.29999995)
            ]
            rel material:binding = </World/Materials/CheckerVisual>
        }
    }

    def Scope "Materials"
    {
        def Material "CheckerVisual"
        {
            token outputs:surface.connect = </World/Materials/CheckerVisual/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor.connect = </World/Materials/CheckerVisual/CheckerTexture.outputs:rgb>
                float inputs:roughness = 0.65
                token outputs:surface
            }

            def Shader "PrimvarReader"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                token inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "CheckerTexture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @deformable_visual_checker.png@
                float2 inputs:st.connect = </World/Materials/CheckerVisual/PrimvarReader.outputs:result>
                token inputs:sourceColorSpace = "sRGB"
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }
        }

        def Material "ClothObstaclePhysics" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI"]
        )
        {
            float physics:staticFriction = 0.5
            float physics:dynamicFriction = 0.5
            float newton:contactStiffness = 100000
            float newton:contactDamping = 10
        }

        def Material "CablePhysics" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "PhysicsCurvesDeformableMaterialAPI"]
        )
        {
            float physics:thickness = 0.07
            float physics:density = 1000
            float physics:bendStiffness = 2121182.08
            float physics:stretchStiffness = 1299224.03
        }

        def Material "ClothPhysics" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "PhysicsSurfaceDeformableMaterialAPI"]
        )
        {
            float physics:thickness = 0.02
            float physics:density = 1000
            float physics:stretchStiffness = 50000
        }

        def Material "VolumePhysics" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "PhysicsVolumeDeformableMaterialAPI"]
        )
        {
            float physics:density = 1000
            float physics:youngsModulus = 50000
            float physics:poissonsRatio = 0.25
        }
    }
}
