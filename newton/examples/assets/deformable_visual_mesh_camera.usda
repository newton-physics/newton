#usda 1.0
(
    defaultPrim = "World"
    doc = "AOUSD deformable scene used by the deformable_visual_mesh_camera example. The topology intentionally mirrors the procedural path where USD can express it; the example applies small builder-side parity overrides for importer/API gaps such as cable damping and cloth area damping."
    metersPerUnit = 1
    upAxis = "Z"
)

def PhysicsScene "PhysicsScene"
{
}

